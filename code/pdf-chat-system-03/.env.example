# Copy this file to `.env` and fill in values, then run `streamlit run app.py`.

# Required. Your OpenAI-compatible API key.
#   - OpenAI:     sk-...          (get from https://platform.openai.com/api-keys)
#   - OpenRouter: sk-or-v1-...    (get from https://openrouter.ai/keys)
OPENAI_API_KEY=

# Required. A chat-capable model name.
#   - OpenAI examples:     gpt-4o-mini, gpt-4o, gpt-4-turbo
#   - OpenRouter examples: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, meta-llama/llama-3.1-70b-instruct
OPENAI_MODEL=

# Optional. Override the API endpoint. 
#   - OpenAI (default): https://api.openai.com/v1
#   - OpenRouter:       https://openrouter.ai/api/v1
#   - Local (Ollama/LM Studio/vLLM): http://localhost:11434/v1 etc.
OPENAI_BASE_URL=https://api.openai.com/v1
